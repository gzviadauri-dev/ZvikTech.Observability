{
  "Observability": {
    "Environment": "Production",

    "Logging": {
      "MinimumLevel": "Information",

      // Keep only 10 % of successful HTTP request logs in production to reduce Graylog costs.
      "SampleSuccessRate": 0.1,

      "Graylog": {
        // Enable GELF TCP sink in production (more reliable than UDP — no datagram size limit).
        "Enabled": true,
        "Host": "graylog",
        "Port": 12201,
        "Protocol": "tcp",
        "Facility": "SampleApi"
      },

      "RateLimit": {
        "Enabled": true,
        "MaxPerWindow": 10,
        "WindowSeconds": 60
      }
    },

    "Telemetry": {
      "Enabled": true,

      "Tracing": {
        "Enabled": true,
        // 10 % head-based sampling in production to reduce Jaeger/storage costs.
        "SamplingRatio": 0.1
      },

      "Metrics": {
        "Enabled": true,
        "PrometheusEnabled": true
      },

      "Otlp": {
        // Export to OTEL Collector in production.
        "Enabled": true,
        "Endpoint": "http://otel-collector:4317",
        "Protocol": "grpc"
      }
    }
  }
}
