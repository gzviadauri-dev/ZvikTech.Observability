{
  // ─────────────────────────────────────────────────────────────────────────────────
  // Company.Observability configuration
  // Bind source: "Observability" section.  All keys map to ObservabilityOptions.
  // ─────────────────────────────────────────────────────────────────────────────────
  "Observability": {

    // [Required] Logical service name — used in logs, traces, and metrics.
    "ServiceName": "SampleApi",

    // Service version shown in telemetry. Defaults to entry-assembly version.
    "ServiceVersion": "1.0.0",

    // Deployment environment label. Defaults to ASPNETCORE_ENVIRONMENT.
    "Environment": "Development",

    // ── Logging ────────────────────────────────────────────────────────────────────
    "Logging": {
      "Enabled": true,

      // Minimum Serilog level.  Verbose | Debug | Information | Warning | Error | Fatal
      "MinimumLevel": "Debug",

      // Paths excluded from per-request log entries (Verbose level = effectively silent).
      "ExcludePaths": [ "/health", "/metrics", "/favicon.ico" ],

      // Keep 100 % of successful HTTP request log events in development.
      // In production, set this to 0.05-0.1 to reduce ingestion costs.
      "SampleSuccessRate": 1.0,

      // Always write compact JSON to stdout (container-friendly fallback sink).
      "EnableConsoleOutput": true,

      // Header name used to propagate the correlation identifier.
      "CorrelationHeaderName": "X-Correlation-Id",

      // ── Graylog ──────────────────────────────────────────────────────────────────
      "Graylog": {
        // Set to true and supply Host to enable GELF sink.
        "Enabled": false,
        // "Host": "graylog",      // hostname or IP of your Graylog GELF input
        "Port": 12201,
        // "tcp" is more reliable for production (no max-UDP-datagram size limit).
        // "udp" has lower overhead for development.
        "Protocol": "udp",
        "Facility": "SampleApi"
      },

      // ── Rate limiting ─────────────────────────────────────────────────────────────
      "RateLimit": {
        // Suppress repeated Warning messages after MaxPerWindow occurrences per window.
        "Enabled": true,
        "MaxPerWindow": 10,
        "WindowSeconds": 60
      }
    },

    // ── Telemetry (OpenTelemetry) ──────────────────────────────────────────────────
    "Telemetry": {
      "Enabled": true,

      "Tracing": {
        "Enabled": true,
        // 1.0 = AlwaysOn; < 1.0 = ParentBased+TraceIdRatioBased.
        "SamplingRatio": 1.0,
        // Paths excluded from span creation.
        "ExcludePaths": [ "/health", "/metrics" ],
        // Set to true AND add the SqlClient NuGet package to enable SqlClient tracing.
        "SqlClientEnabled": false
      },

      "Metrics": {
        "Enabled": true,
        // Exposes /metrics for Prometheus scraping.  Requires UseCompanyObservability().
        "PrometheusEnabled": false
      },

      // ── OTLP exporter ─────────────────────────────────────────────────────────────
      "Otlp": {
        // Set to true to export traces and metrics to an OpenTelemetry Collector.
        "Enabled": false,
        // "Endpoint": "http://otel-collector:4317",
        "Endpoint": "http://localhost:4317",
        // "grpc" (default) or "http/protobuf"
        "Protocol": "grpc"
        // Optional auth headers — values are never written to logs.
        // "Headers": { "x-honeycomb-team": "YOUR_KEY" }
      }
    },

    // ── PII / secrets redaction ────────────────────────────────────────────────────
    "Redaction": {
      // Keys merged WITH the built-in defaults (not a replacement).
      // Example: add "nationalId" to redact a domain-specific field.
      "SensitiveKeys": []
    }
  },

  // ── Serilog level overrides (optional — overrides MinimumLevel per namespace) ────
  // This section is read by ReadFrom.Configuration() inside the Serilog pipeline.
  "Serilog": {
    "MinimumLevel": {
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    }
  },

  // Standard ASP.NET Core logging — left intact for non-Serilog scenarios.
  "AllowedHosts": "*"
}
